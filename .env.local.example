NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JWT_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Ad Tracking (set when ready to run ads — everything works without these)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-xxxxxxxxxx
NEXT_PUBLIC_FB_PIXEL_ID=your_facebook_pixel_id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Telegram Bots (webhook routes)
CLAUDECODE_BOT_TOKEN=your_claudecode_bot_token
CLAWDIRECTOR_BOT_TOKEN=your_clawdirector_bot_token
CLAWDIRECTOR_CHAT_ID=your_clawdirector_chat_id

# Todoist
TODOIST_TOKEN=your_todoist_token

# Admin
ADMIN_EMAILS=email1@example.com,email2@example.com

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_ADDRESS=Your App <hello@yourdomain.com>
RESEND_REPLY_TO=hello@yourdomain.com
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=your_stripe_pro_price_id
STRIPE_POWER_PRICE_ID=your_stripe_power_price_id

# Anthropic (AI enrichment)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cron Auth
CRON_SECRET=your_cron_secret

# Proof of Work
POW_SECRET=your_pow_secret

# Eventbrite
EVENTBRITE_API_TOKEN=your_eventbrite_token
